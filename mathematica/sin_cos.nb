         RowBox[{"\[Mu]", "/", 
          RowBox[{"2", "^", 
           RowBox[{"(", 
            RowBox[{"significandBits", "-", "1"}], ")"}]}]}], " ", 
         RowBox[{"2", "^", 
          RowBox[{"(", 
           RowBox[{"1", "-", "bias"}], ")"}]}]}], ",", "\n", 
        RowBox[{"sign", 
         RowBox[{"(", 
          RowBox[{"1", "+", 
           RowBox[{"\[Mu]", "/", 
            RowBox[{"2", "^", 
             RowBox[{"(", 
              RowBox[{"significandBits", "-", "1"}], ")"}]}]}]}], ")"}], 
         RowBox[{"2", "^", 
          RowBox[{"(", 
           RowBox[{"e", "-", "bias"}], ")"}]}]}]}], "]"}]}]}], "]"}]}], 
