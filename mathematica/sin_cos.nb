Cell[CellGroupData[{

Cell["Polynomials", "Section",
 CellChangeTimes->{{3.9615762186815414`*^9, 
  3.9615762295113144`*^9}},ExpressionUUID->"2dabf330-21b9-674b-b99c-\
0890b1da5070"],

Cell[TextData[{
 "This section derives the minimax polynomials used to approximate ",
 StyleBox["Sin", "Code"],
 " and ",
 StyleBox["Cos", "Code"],
 "."
}], "Text",
 CellChangeTimes->{{3.961576235225193*^9, 
  3.961576256376543*^9}},ExpressionUUID->"8ccbf52d-53ac-3d41-9e49-\
68a82d731e13"],

Cell[CellGroupData[{

Cell["Sin", "Subsection",
 CellChangeTimes->{{3.961576260814907*^9, 
  3.961576267970333*^9}},ExpressionUUID->"6db8d246-449e-4440-8e93-\
a1166e414158"],

Cell[TextData[{
 "We want to compute minimax polynomials that are odd and where the term in ",
 StyleBox["t", "Code"],
 " is linear so that the computation produces two terms, ",
 StyleBox["t", "Code"],
 " plus a correction.  Therefore, we approximate the function ",
 StyleBox["sinFn", "Code"],
 " below.  Note that it is singular near 0 and must therefore be replaced by \
its limit there."
}], "Text",
 CellChangeTimes->{{3.926825445501383*^9, 3.926825446994425*^9}, {
  3.9268254859092083`*^9, 3.9268255832380905`*^9}, {3.9268256172570934`*^9, 
  3.9268256879708805`*^9}},ExpressionUUID->"f1c24959-6ab0-a041-b351-\
eff8a0f62eb3"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Series", "[", 
  RowBox[{
   RowBox[{"Sin", "[", "t", "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"t", ",", "0", ",", "5"}], "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.92441900959511*^9, 3.924419021217657*^9}, {
  3.924519295859869*^9, 3.9245192999397736`*^9}},
 CellLabel->"In[12]:=",ExpressionUUID->"c23b168b-b7c0-0a4a-ade6-2abe15a364b6"],

Cell[BoxData[
 InterpretationBox[
  RowBox[{"t", "-", 
   FractionBox[
    SuperscriptBox["t", "3"], "6"], "+", 
   FractionBox[
    SuperscriptBox["t", "5"], "120"], "+", 
   InterpretationBox[
    SuperscriptBox[
     RowBox[{"O", "[", "t", "]"}], "6"],
    SeriesData[$CellContext`PolynomialsSin`t, 0, {}, 1, 6, 1],
    Editable->False]}],
  SeriesData[$CellContext`PolynomialsSin`t, 0, {1, 0, 
    Rational[-1, 6], 0, 
    Rational[1, 120]}, 1, 6, 1],
  Editable->False]], "Output",
 CellChangeTimes->{
  3.92441902177482*^9, 3.924422484195503*^9, {3.9245193005342464`*^9, 
   3.924519316439907*^9}, 3.925193777490601*^9, 3.925309748109428*^9, 
