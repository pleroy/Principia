Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", "mantissaExponent12", "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"mantissaExponent12", "[", 
    RowBox[{"x_", "?", "NumericQ"}], "]"}], ":=", "\n", "\t", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"\[Mu]", ",", "e"}], "}"}], ",", 
     RowBox[{
      RowBox[{
       RowBox[{"{", 
        RowBox[{"\[Mu]", ",", "e"}], "}"}], "=", 
