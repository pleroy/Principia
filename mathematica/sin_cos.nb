Cell["\<\
Find the bounds over which we\[CloseCurlyQuote]ll have to evaluate the \
polynomial, based on the excursion away from multiples of 1/512:\
\>", "Text",
 CellChangeTimes->{{3.9616562773059616`*^9, 
  3.9616563266097813`*^9}},ExpressionUUID->"0843ec6b-abde-4e43-ad0b-\
d7c6bd7d6b39"],

Cell[BoxData[
 RowBox[{
  RowBox[{"accurateTablesIntervals", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"With", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"t", "=", 
         RowBox[{"accurateTables", "[", "i", "]"}]}], "}"}], ",", 
       RowBox[{"Interval", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"(", 
             RowBox[{
              RowBox[{"2", "i"}], "-", "1"}], ")"}], "/", "1024"}], "-", 
           RowBox[{"t", "[", 
            RowBox[{"[", "1", "]"}], "]"}]}], ",", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{
               RowBox[{"2", "i"}], "+", "1"}], ")"}], "/", "1024"}], "-", 
            RowBox[{"t", "[", 
             RowBox[{"[", "1", "]"}], "]"}]}], ")"}]}], "}"}], "]"}]}], "]"}],
      ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", "accurateTablesMaxIndex"}], "}"}]}], 
    "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.9620046420678215`*^9, 3.9620046927738323`*^9}, {
  3.962004769850748*^9, 3.962004822597933*^9}},
 CellLabel->
  "In[110]:=",ExpressionUUID->"6500b48a-eeb7-9d40-a55d-58f250fc3286"],

