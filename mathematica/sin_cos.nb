Cell["\<\
This error preserves 19 bits after the mantissa of the result, which is \
sufficient for ensuring correct rounding with high probability.\
\>", "Text",
 CellChangeTimes->{{3.961647040505085*^9, 3.961647078983616*^9}, {
  3.9621900040392914`*^9, 3.9621900052202625`*^9}, {3.962350677033039*^9, 
