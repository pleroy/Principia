4c6e5a4fa227"],

Cell[CellGroupData[{

Cell["Argument Reduction Using the Two - Term Approximation", "Subsection",
 CellChangeTimes->{{3.96010923041498*^9, 
  3.9601092661024*^9}},ExpressionUUID->"5e4cd0b0-782d-284b-9ab2-d26e9853fbcc"],

Cell[BoxData[
 RowBox[{
  RowBox[{"xInterval", "=", 
   RowBox[{"Interval", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"-", 
        RowBox[{"2", "^", "\[Kappa]1"}]}], " ", 
       RowBox[{"CorrectlyRound", "[", 
        RowBox[{"\[Pi]", "/", "2"}], "]"}]}], ",", 
      RowBox[{
       RowBox[{"2", "^", "\[Kappa]1"}], " ", 
       RowBox[{"CorrectlyRound", "[", 
        RowBox[{"\[Pi]", "/", "2"}], "]"}]}]}], "}"}], "]"}]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.960109554792673*^9, 3.9601096015308876`*^9}},
 CellLabel->"In[40]:=",ExpressionUUID->"0eb813eb-cdac-0f45-966e-350ff177373f"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"nIntervals", "=", 
  RowBox[{"IEEEEvaluateWithRelativeError", "[", 
   RowBox[{"xInterval", " ", 
    RowBox[{"CorrectlyRound", "[", 
     RowBox[{"2", "/", "\[Pi]"}], "]"}]}], "]"}]}]], "Input",
 CellChangeTimes->{
  3.9601197033441505`*^9, {3.960541543865122*^9, 3.960541550771305*^9}, {
