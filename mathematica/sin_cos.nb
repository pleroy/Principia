Cell[BoxData[
 RowBox[{
  RowBox[{"sin0ImplementationRelativeError", "[", 
   RowBox[{"x_", ",", "e_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{
    RowBox[{"(", 
     RowBox[{"x", "+", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{"1", "-", "\[Delta]1"}], ")"}], 
             RowBox[{"Sin", "[", "x", "]"}]}], "-", "x"}], ")"}], 
          RowBox[{"(", 
           RowBox[{"1", "+", "\[Delta]2"}], ")"}]}], "+", "e"}], ")"}], 
       RowBox[{"(", 
        RowBox[{"1", "+", "\[Delta]3"}], ")"}]}]}], ")"}], "/", 
    RowBox[{"Sin", "[", 
     RowBox[{"x", "+", "e"}], "]"}]}], "-", "1"}]}]], "Input",
 CellChangeTimes->{{3.962278114928465*^9, 3.9622781804000263`*^9}, {
   3.9622787143907127`*^9, 3.9622787204422417`*^9}, {3.9622789841332703`*^9, 
