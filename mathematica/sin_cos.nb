Cell[CellGroupData[{

Cell["Near  Zero", "Subsubsection",
 CellChangeTimes->{{3.925310084693428*^9, 3.9253100974896793`*^9}, {
  3.961576448562563*^9, 
  3.961576450580511*^9}},ExpressionUUID->"40afd113-817a-2041-a977-\
a7cf7d549569"],

Cell[TextData[{
 "Near zero the Gal and Bachelis method is not usable, so we use a plain \
minimax polynomial for the entire function.  We want it to be odd and we want \
to separate out the ",
 StyleBox["t", "Code"],
 " term so we use the ",
 StyleBox["sinFn", "Code"],
 " function with an error function suitable for the ",
 StyleBox["relative",
  FontSlant->"Italic"],
 " error."
}], "Text",
 CellChangeTimes->{{3.92682855662339*^9, 3.926828710915291*^9}, {
  3.9616450450271664`*^9, 3.961645055893944*^9}, {3.961654216814844*^9, 
  3.961654221539011*^9}},ExpressionUUID->"c1e0e358-4f08-5d44-84fe-\
0dc2153e0a14"],

