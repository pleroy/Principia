Cell[CellGroupData[{

Cell["Between Table Entries", "Subsubsection",
 CellChangeTimes->{{3.925310084693428*^9, 3.9253100974896793`*^9}, {
  3.961576448562563*^9, 3.961576450580511*^9}, {3.9616541961135693`*^9, 
  3.961654200599966*^9}},ExpressionUUID->"f10c5ef7-5a1f-c940-a87e-\
a41a34d8549d"],

Cell[TextData[{
 "We want the minimax polynomial to be odd and we want to separate out the ",
 StyleBox["t", "Code"],
 " term so we use the ",
 StyleBox["sinFn", "Code"],
 " function with an error function suitable for the ",
 StyleBox["absolute",
  FontSlant->"Italic"],
 " error."
}], "Text",
 CellChangeTimes->{{3.92682855662339*^9, 3.926828710915291*^9}, {
  3.9616450450271664`*^9, 3.961645055893944*^9}, {3.961654243918354*^9, 
  3.9616542833519115`*^9}, {3.9619929579966354`*^9, 
  3.9619929590330715`*^9}},ExpressionUUID->"30997674-c3eb-c942-a447-\
9edb3e230dc2"],

