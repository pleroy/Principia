 RowBox[{
  RowBox[{
   RowBox[{"{", 
    RowBox[{"ub", ",", "lb"}], "}"}], "=", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"1", "/", "512"}], ",", 
      RowBox[{
       RowBox[{"-", "1"}], "/", "512"}]}], "}"}], "-", 
    RowBox[{"MinMax", "[", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"accurateTables", "[", "i", "]"}], "[", 
         RowBox[{"[", "1", "]"}], "]"}], "-", 
        RowBox[{"i", "/", "512"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "1", ",", "accurateTableMaxIndex"}], "}"}]}], "]"}],
      "]"}]}]}], ";"}]], "Input",
