Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", "FromRepresentation", "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"FromRepresentation", "[", "n_", "]"}], ":=", 
   RowBox[{"Module", "[", "\n", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"sign", ",", "magnitude", ",", "\[Mu]", ",", "e"}], "}"}], ",", 
     "\n", 
     RowBox[{
      RowBox[{"sign", "=", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"n", ">=", 
          RowBox[{"2", "^", 
           RowBox[{"(", 
            RowBox[{"exponentBits", "+", "significandBits", "-", "1"}], 
            ")"}]}]}], ",", 
         RowBox[{"-", "1"}], ",", "1"}], "]"}]}], ";", "\n", 
      RowBox[{"magnitude", "=", 
       RowBox[{"Mod", "[", 
        RowBox[{"n", ",", 
         RowBox[{"2", "^", 
          RowBox[{"(", 
           RowBox[{"exponentBits", "+", "significandBits", "-", "1"}], 
           ")"}]}]}], "]"}]}], ";", "\n", 
      RowBox[{"\[Mu]", "=", 
       RowBox[{"Mod", "[", 
        RowBox[{"magnitude", ",", 
         RowBox[{"2", "^", 
          RowBox[{"(", 
           RowBox[{"significandBits", "-", "1"}], ")"}]}]}], "]"}]}], ";", 
      "\n", 
