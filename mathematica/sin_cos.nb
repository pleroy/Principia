Cell[BoxData[
 RowBox[{
  RowBox[{"hasAccurateTables", "[", "i_", "]"}], ":=", 
  RowBox[{"ValueQ", "[", 
   RowBox[{
    RowBox[{"accurateTables", "[", "i", "]"}], ",", 
    RowBox[{"Method", "->", "\"\<TrialEvaluation\>\""}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.9616552457746716`*^9, 3.961655265608713*^9}, {
