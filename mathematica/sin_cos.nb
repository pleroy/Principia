Cell[BoxData[
 RowBox[{
  RowBox[{"Collect", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"Normal", "[", 
      RowBox[{"Series", "[", 
       RowBox[{
        RowBox[{"Sin", "[", "u", "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"u", ",", "0", ",", "5"}], "}"}]}], "]"}], "]"}], "/.", 
     RowBox[{"u", "->", 
      RowBox[{"(", 
       RowBox[{"x", "+", "e"}], ")"}]}]}], ",", "e"}], "]"}], "/.", 
  RowBox[{"(", 
   RowBox[{
    RowBox[{"e", "^", "n_"}], ":>", 
