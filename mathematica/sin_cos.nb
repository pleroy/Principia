          RowBox[{"(", 
           RowBox[{"significandBits", "-", "1"}], ")"}]}]}], "]"}]}], ";", 
      "\n", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"e", "==", "0"}], ",", "\n", 
