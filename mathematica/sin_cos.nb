   SuperscriptBox["x", "3"], "6"], "+", 
  FractionBox[
   SuperscriptBox["x", "5"], "120"], "+", 
  RowBox[{"e", " ", 
   RowBox[{"(", 
    RowBox[{"1", "-", 
     FractionBox[
