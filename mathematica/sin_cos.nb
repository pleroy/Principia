Cell[TextData[{
 "We the minimax polynomial to be odd and we want to separate out the ",
 StyleBox["t", "Code"],
 " term so we use the ",
 StyleBox["sinFn", "Code"],
 " function with an error function suitable for the ",
 StyleBox["absolute",
  FontSlant->"Italic"],
 " error."
}], "Text",
 CellChangeTimes->{{3.92682855662339*^9, 3.926828710915291*^9}, {
