           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{
               RowBox[{"2", "i"}], "+", "1"}], ")"}], "/", "1024"}], "-", 
            RowBox[{"t", "[", 
             RowBox[{"[", "1", "]"}], "]"}]}], ")"}]}], "}"}], "]"}]}], "]"}],
