Cell[BoxData[
 RowBox[{"Plot3D", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Min", "[", 
      RowBox[{"sin0ImplementationRelativeError", "[", 
       RowBox[{"x", ",", "e"}], "]"}], "]"}], ",", 
     RowBox[{"Max", "[", 
      RowBox[{"sin0ImplementationRelativeError", "[", 
       RowBox[{"x", ",", "e"}], "]"}], "]"}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", "0", ",", "max"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"e", ",", 
     RowBox[{
      RowBox[{"-", "max"}], " ", 
      RowBox[{"\[GothicU]", "[", 
       RowBox[{"1", "/", "2"}], "]"}]}], ",", 
     RowBox[{"max", " ", 
      RowBox[{"\[GothicU]", "[", 
       RowBox[{"1", "/", "2"}], "]"}]}]}], "}"}], ",", 
   RowBox[{"RegionFunction", "->", 
    RowBox[{"Function", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"x", ",", "e"}], "}"}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"-", "x"}], " ", 
        RowBox[{"\[GothicU]", "[", 
         RowBox[{"1", "/", "2"}], "]"}]}], "<", "e", "<", 
       RowBox[{"x", " ", 
        RowBox[{"\[GothicU]", "[", 
         RowBox[{"1", "/", "2"}], "]"}]}]}]}], "]"}]}], ",", 
   RowBox[{"WorkingPrecision", "->", "40"}], ",", 
   RowBox[{"MeshShading", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"Automatic", ",", "None"}], "}"}], ",", 
