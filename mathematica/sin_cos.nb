    RowBox[{"Print", "[", 
     RowBox[{"FullForm", "[", "x", "]"}], "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{"ClearAll", "[", "Representation", "]"}], ";"}], "\n", 
