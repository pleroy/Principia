Cell["\<\
This error preserves 20 bits after the mantissa of the result, which is \
sufficient for ensuring correct rounding with high probability.\
\>", "Text",
 CellChangeTimes->{{3.961647040505085*^9, 
  3.961647078983616*^9}},ExpressionUUID->"e3bce6dd-5392-0940-93fa-\
f697d25b1c30"],

