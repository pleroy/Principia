 RowBox[{
  RowBox[{"accurateTablesErrors", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"With", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"t", "=", 
         RowBox[{"accurateTables", "[", "i", "]"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"N", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Sin", "[", 
             RowBox[{"t", "[", 
              RowBox[{"[", "1", "]"}], "]"}], "]"}], "-", 
            RowBox[{"CorrectlyRound", "[", 
             RowBox[{"t", "[", 
              RowBox[{"[", "2", "]"}], "]"}], "]"}]}], ",", "30"}], "]"}], ",", 
         RowBox[{"N", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Cos", "[", 
             RowBox[{"t", "[", 
              RowBox[{"[", "1", "]"}], "]"}], "]"}], "-", 
            RowBox[{"CorrectlyRound", "[", 
             RowBox[{"t", "[", 
              RowBox[{"[", "3", "]"}], "]"}], "]"}]}], ",", "30"}], "]"}]}], 
        "}"}]}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", "accurateTablesMaxIndex"}], "}"}]}], 
    "]"}]}], ";"}]], "Input",
