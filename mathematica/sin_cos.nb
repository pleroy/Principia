  FormBox[
   SuperscriptBox["x", "2"], TraditionalForm]],ExpressionUUID->
  "2de42fcc-d292-8440-a9dc-b051efcfb0a6"],
 " doesn\[CloseCurlyQuote]t matter:"
}], "Text",
 CellChangeTimes->{{3.9622641999943066`*^9, 
  3.9622642198791275`*^9}},ExpressionUUID->"0189afd2-2f12-e145-8750-\
26f4279bf279"],

