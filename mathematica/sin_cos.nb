Cell[BoxData[
 InterpretationBox[
  StyleBox[
   FrameBox[
    DynamicModuleBox[{System`InformationDump`open$$ = False, 
     System`InformationDump`mouseOver$$ = False}, 
     PaneSelectorBox[{True->
      TagBox[GridBox[{
         {
          ItemBox[
           PaneBox[
            StyleBox[
             TagBox[
              TooltipBox[
               StyleBox["\<\" Symbol\"\>", "InformationRowLabel",
                StripOnInput->False],
               "\"Symbol\"",
               TooltipStyle->"TextStyling"],
              Annotation[#, "Symbol", "Tooltip"]& ], "InformationTitleText",
             StripOnInput->False,
             BaseStyle -> None],
            FrameMargins->{{4, 0}, {-1, 1}}],
           BaseStyle->"InformationTitleBackground",
           StripOnInput->False], 
          ItemBox["\<\"\"\>",
           BaseStyle->"InformationTitleBackground",
           StripOnInput->False]},
         {
          ItemBox[
           PaneBox[
            
            StyleBox["\<\"IEEEEvaluateWithRelativeeError[\\!\\(\\*StyleBox[\\\
\"x\\\",\\nFontSlant->\\\"Italic\\\"]\\)] evaluates \\!\\(\\*StyleBox[\\\"x\\\
\",\\nFontSlant->\\\"Italic\\\"]\\) using the rules of IEEE arithmetic, and \
propagates the relative error bounds at each stage of the computation.  \
Returns a list of two intervals: the first one is the interval of the result \
evaluated with proper IEEE rounding, the second one is the range of the \
relative error on the result.  The argument is an expression which can \
include numbers (assumed to be exact after correct rounding), intervals \
(assumed to not carry any error), or a list of two intervals for a value and \
its relative error.\"\>", "InformationUsageText",
             StripOnInput->False,
             LineSpacing->{1.5, 1.5, 3.}],
            FrameMargins->{{10, 10}, {8, 10}}],
           BaseStyle->"InformationUsageSubtitleBackground",
           StripOnInput->False], 
          ItemBox["\<\"\"\>",
           BaseStyle->"InformationUsageSubtitleBackground",
           StripOnInput->False]},
         {
          PaneBox[
           TagBox[GridBox[{
              {
               StyleBox[
                TagBox[
                 TooltipBox[
                  StyleBox["\<\" Definitions\"\>", "InformationRowLabel",
                   StripOnInput->False],
                  "\"Definitions\"",
                  TooltipStyle->"TextStyling"],
                 Annotation[#, "Definitions", "Tooltip"]& ], "DialogStyle",
                StripOnInput->False]},
              {
               TemplateBox[{"\"\[ThinSpace]\"", 
                 GridBox[{{
                    RowBox[{
                    RowBox[{"IEEEEvaluateWithRelativeError", "[", 
                    RowBox[{"IEEE754FloatingPointEvaluation`Private`x_", ",", 
                    RowBox[{"OptionsPattern", "[", "]"}]}], "]"}], ":=", 
                    RowBox[{"Block", "[", 
                    RowBox[{
                    RowBox[{"{", 
                    
                    RowBox[{"Plus", ",", "Times", ",", 
                    "IEEE754FloatingPointEvaluation`Private`evre", ",", 
                    
                    RowBox[{"IEEE754FloatingPointEvaluation`Private`usefma", 
                    "=", 
                    RowBox[{"OptionValue", "[", "UseFMA", "]"}]}]}], "}"}], 
                    ",", 
                    RowBox[{
                    RowBox[{"SetAttributes", "[", 
                    
                    RowBox[{"IEEE754FloatingPointEvaluation`Private`evre", 
                    ",", "HoldAll"}], "]"}], ";", 
                    RowBox[{
                    
                    RowBox[{"Options", "[", 
                    "IEEE754FloatingPointEvaluation`Private`evre", "]"}], "=", 
                    RowBox[{"{", 
                    RowBox[{"Exact", "\[Rule]", "False"}], "}"}]}], ";", 
                    RowBox[{
                    
                    RowBox[{"IEEE754FloatingPointEvaluation`Private`evre", 
                    "[", 
                    RowBox[{
                    RowBox[{
                    
                    RowBox[{"IEEE754FloatingPointEvaluation`Private`a_", " ", 
                    "IEEE754FloatingPointEvaluation`Private`b_"}], "+", 
                    "IEEE754FloatingPointEvaluation`Private`c_"}], ",", 
                    
                    RowBox[{"IEEE754FloatingPointEvaluation`Private`opts", 
                    ":", 
                    RowBox[{"OptionsPattern", "[", "]"}]}]}], "]"}], ":=", 
                    RowBox[{"If", "[", 
                    
                    RowBox[{"IEEE754FloatingPointEvaluation`Private`usefma", 
                    ",", 
                    
                    RowBox[{
                    "IEEE754FloatingPointEvaluation`Private`\
applyOpWithRelativeError", "[", 
                    RowBox[{"IEEE754FloatingPointEvaluation`Private`fma", ",", 
                    
                    RowBox[{"IEEE754FloatingPointEvaluation`Private`evre", 
                    "[", "IEEE754FloatingPointEvaluation`Private`a", "]"}], 
                    ",", 
                    
                    RowBox[{"IEEE754FloatingPointEvaluation`Private`evre", 
                    "[", "IEEE754FloatingPointEvaluation`Private`b", "]"}], 
                    ",", 
                    
                    RowBox[{"IEEE754FloatingPointEvaluation`Private`evre", 
                    "[", "IEEE754FloatingPointEvaluation`Private`c", "]"}], 
                    ",", "IEEE754FloatingPointEvaluation`Private`opts"}], 
                    "]"}], ",", 
                    
                    RowBox[{
                    "IEEE754FloatingPointEvaluation`Private`\
applyOpWithRelativeError", "[", 
                    RowBox[{"Plus", ",", 
                    
                    RowBox[{
                    "IEEE754FloatingPointEvaluation`Private`\
applyOpWithRelativeError", "[", 
                    RowBox[{"Times", ",", 
                    
                    RowBox[{"IEEE754FloatingPointEvaluation`Private`evre", 
                    "[", "IEEE754FloatingPointEvaluation`Private`a", "]"}], 
                    ",", 
                    
                    RowBox[{"IEEE754FloatingPointEvaluation`Private`evre", 
                    "[", "IEEE754FloatingPointEvaluation`Private`b", "]"}], 
                    ",", "IEEE754FloatingPointEvaluation`Private`opts"}], 
                    "]"}], ",", 
                    
                    RowBox[{"IEEE754FloatingPointEvaluation`Private`evre", 
                    "[", "IEEE754FloatingPointEvaluation`Private`c", "]"}], 
                    ",", "IEEE754FloatingPointEvaluation`Private`opts"}], 
                    "]"}]}], "]"}]}], ";", 
                    RowBox[{
                    
