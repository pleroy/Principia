Cell["\<\
The floating-point evaluation and rounding errors increase the overall \
relative error on the bounds of the interval.  Therefore, a smaller interval \
will give comparatively smaller errors:\
\>", "Text",
 CellChangeTimes->{{3.9616470115044327`*^9, 3.9616470175136223`*^9}, {
  3.9616476309450397`*^9, 3.961647649949999*^9}, {3.9619071940992203`*^9, 
  3.9619072363101177`*^9}, {3.9621899212752438`*^9, 
  3.962189934790516*^9}},ExpressionUUID->"2f31ffd3-19b3-9446-b56a-\
4b037a81195a"],

Cell[BoxData[
 RowBox[{
  RowBox[{"sin0ApproximationOverallRelativeError", "[", "x_", "]"}], ":=", 
  RowBox[{
   RowBox[{"x", "/", 
    RowBox[{"Sin", "[", "x", "]"}]}], "+", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"1", "+", 
      RowBox[{"Interval", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"-", "\[Eta]"}], ",", "\[Eta]"}], "}"}], "]"}], "-", 
      RowBox[{"x", "/", 
       RowBox[{"Sin", "[", "x", "]"}]}]}], ")"}], 
    RowBox[{"(", 
     RowBox[{"1", "-", 
      RowBox[{"sin0ApproximationIEEEIntervals", "[", 
       RowBox[{"[", "2", "]"}], "]"}]}], ")"}]}], "-", "1"}]}]], "Input",
 CellChangeTimes->{{3.96218538196912*^9, 3.9621854133488674`*^9}, {
  3.9621854593951836`*^9, 3.962185510420925*^9}, {3.962185574627426*^9, 
  3.9621856187040806`*^9}, {3.9621858862779255`*^9, 3.9621859066518974`*^9}, {
  3.9621887468189583`*^9, 3.9621887513181496`*^9}, {3.9621898434580803`*^9, 
  3.9621898565258617`*^9}},
 CellLabel->
  "In[220]:=",ExpressionUUID->"2be790fd-dd2e-9643-8502-a8658cfd3aa3"],

Cell[CellGroupData[{

Cell[BoxData[
