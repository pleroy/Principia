   3.9619069715990486`*^9, 3.961907002886751*^9}, {3.9619070356111107`*^9, 
   3.961907059795828*^9}},
 CellLabel->"In[53]:=",ExpressionUUID->"c6e57768-8f33-0f4b-ab1a-48fcb3506528"],

