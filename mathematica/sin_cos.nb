Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"{", 
    RowBox[{"ub", ",", "lb"}], "}"}], "=", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"1", "/", "512"}], ",", 
      RowBox[{
       RowBox[{"-", "1"}], "/", "512"}]}], "}"}], "-", 
    RowBox[{"MinMax", "[", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"accurateTables", "[", "i", "]"}], "[", 
         RowBox[{"[", "1", "]"}], "]"}], "-", 
        RowBox[{"i", "/", "512"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "1", ",", "accurateTableMaxIndex"}], "}"}]}], "]"}],
      "]"}]}]}], ";"}]], "Input",
 CellChangeTimes->{{3.9616546546089993`*^9, 3.9616547330126934`*^9}, {
   3.961654779156719*^9, 3.9616548082853737`*^9}, {3.9616554338297043`*^9, 
