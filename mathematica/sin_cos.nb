Cell["\<\
This error preserves a bit more than 18 bits after the mantissa of the \
result, which is (barely) sufficient for ensuring correct rounding with high \
probability.\
\>", "Text",
 CellChangeTimes->{{3.961647040505085*^9, 3.961647078983616*^9}, {
  3.9620010525953274`*^9, 3.962001052723322*^9}, {3.9620060548418617`*^9, 
