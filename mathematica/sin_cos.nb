Cell["\<\
The floating-point evaluation and rounding errors increase the overall \
relative error because of the factor \[Alpha].  Therefore, a smaller interval \
will give comparatively smaller errors:\
\>", "Text",
 CellChangeTimes->{{3.9616470115044327`*^9, 3.9616470175136223`*^9}, {
  3.9616476309450397`*^9, 3.961647649949999*^9}, {3.9619071940992203`*^9, 
  3.9619072363101177`*^9}},ExpressionUUID->"2f31ffd3-19b3-9446-b56a-\
4b037a81195a"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"sin0RelativeErrors", "=", 
  RowBox[{
   RowBox[{"Interval", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"1", "+", "\[Zeta]\[FilledDownTriangle]"}], ")"}], 
        RowBox[{"(", 
         RowBox[{"1", "-", "\[Eta]"}], ")"}]}], "-", 
       RowBox[{"\[Alpha]", " ", "\[Zeta]\[FilledDownTriangle]"}]}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"1", "+", "\[Eta]"}], ")"}], 
        RowBox[{"(", 
         RowBox[{"1", "-", "\[Zeta]\[FilledUpTriangle]"}], ")"}]}], "+", 
       RowBox[{"\[Alpha]", " ", "\[Zeta]\[FilledUpTriangle]"}]}]}], "}"}], 
    "]"}], "-", "1"}]}]], "Input",
 CellChangeTimes->{{3.9616588365006313`*^9, 3.9616589150720806`*^9}, {
   3.9616590540204964`*^9, 3.9616590577121544`*^9}, {3.9616601967753277`*^9, 
   3.9616603177626324`*^9}, {3.9618436018856487`*^9, 3.961843607587179*^9}, 
   3.9619067023148594`*^9, {3.961906852820633*^9, 3.9619068872644176`*^9}, {
   3.9619069715990486`*^9, 3.961907002886751*^9}, {3.9619070356111107`*^9, 
   3.961907059795828*^9}},
 CellLabel->
  "In[127]:=",ExpressionUUID->"c6e57768-8f33-0f4b-ab1a-48fcb3506528"],

