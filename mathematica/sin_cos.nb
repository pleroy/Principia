 RowBox[{"accurateTablesMaxIndex", "=", 
  RowBox[{"Do", "[", 
   RowBox[{
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{"!", 
       RowBox[{"hasAccurateTables", "[", "i", "]"}]}], ",", 
      RowBox[{"Return", "[", 
       RowBox[{"i", "-", "1"}], "]"}]}], "]"}], ",", 
