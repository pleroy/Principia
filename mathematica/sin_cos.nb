Cell[BoxData[
 RowBox[{
  RowBox[{"sinImplementationMaxRelativeError", "[", "i_", "]"}], ":=", 
  RowBox[{"Module", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"at", "=", 
       RowBox[{"accurateTables", "[", "i", "]"}]}], ",", 
      RowBox[{"m", "=", 
       RowBox[{"Max", "[", 
        RowBox[{"Abs", "[", 
         RowBox[{"accurateTablesIntervals", "[", 
          RowBox[{"[", "i", "]"}], "]"}], "]"}], "]"}]}], ",", "aec", ",", 
      "corners"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"corners", "=", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"0", ",", 
          RowBox[{
           RowBox[{"-", "m"}], " ", 
           RowBox[{"\[GothicU]", "[", 
            RowBox[{"1", "/", "2"}], "]"}]}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"0", ",", 
          RowBox[{"m", " ", 
           RowBox[{"\[GothicU]", "[", 
            RowBox[{"1", "/", "2"}], "]"}]}]}], "}"}], ",", 
        RowBox[{"{", 
