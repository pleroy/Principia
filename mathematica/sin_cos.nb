Cell[CellGroupData[{

Cell["Sin Near  Zero", "Subsection",
 CellChangeTimes->{{3.925310084693428*^9, 3.9253100974896793`*^9}, {
  3.961576448562563*^9, 3.961576450580511*^9}, {3.962164662062992*^9, 
  3.962164663020975*^9}},ExpressionUUID->"40afd113-817a-2041-a977-\
a7cf7d549569"],

Cell[TextData[{
 "Near zero the Gal and Bachelis method is not usable, so we use a plain \
minimax polynomial for the entire function.  We use the ",
 StyleBox["sinFn", "Code"],
 " function with an error function suitable for the ",
 StyleBox["relative",
  FontSlant->"Italic"],
 " error."
}], "Text",
 CellChangeTimes->{{3.92682855662339*^9, 3.926828710915291*^9}, {
