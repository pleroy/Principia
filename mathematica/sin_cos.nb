Cell["Proof that rounding is safe:", "Text",
 CellChangeTimes->{{3.960542025408863*^9, 
  3.9605420422324543`*^9}},ExpressionUUID->"391496c2-5217-0545-8ae4-\
323315c34819"],

Cell[BoxData[
 RowBox[{"Assert", "[", 
  RowBox[{
   RowBox[{"Max", "[", 
    RowBox[{"Abs", "[", "nIntervalBeforeRounding", "]"}], "]"}], "<=", 
   RowBox[{
    RowBox[{"2", "^", "\[Kappa]1"}], 
    RowBox[{"(", 
     RowBox[{"1", "+", 
      RowBox[{"\[Gamma]", "[", "3", "]"}]}], ")"}]}]}], "]"}]], "Input",
 CellChangeTimes->{{3.960541667612322*^9, 3.9605417372456226`*^9}, {
