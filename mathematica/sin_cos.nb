Cell[BoxData[
 RowBox[{
  RowBox[{"Collect", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"Normal", "[", 
      RowBox[{"Series", "[", 
       RowBox[{
        RowBox[{"Sin", "[", "u", "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"u", ",", "0", ",", "5"}], "}"}]}], "]"}], "]"}], "/.", 
     RowBox[{"u", "->", 
      RowBox[{"(", 
       RowBox[{"x", "+", "e"}], ")"}]}]}], ",", "e"}], "]"}], "/.", 
  RowBox[{"(", 
   RowBox[{
    RowBox[{"e", "^", "n_"}], ":>", 
    RowBox[{"0", "/;", 
     RowBox[{"n", ">=", "2"}]}]}], ")"}]}]], "Input",
 CellChangeTimes->{{3.9623507577468395`*^9, 3.962350784491724*^9}},
 CellLabel->
  "In[142]:=",ExpressionUUID->"e1d7aa7e-4fc5-b748-bb42-184c95d84c74"],

Cell[BoxData[
 RowBox[{"x", "-", 
