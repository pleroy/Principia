              RowBox[{"[", "1", "]"}], "]"}], "]"}], "-", 
            RowBox[{"CorrectlyRound", "[", 
             RowBox[{"t", "[", 
              RowBox[{"[", "2", "]"}], "]"}], "]"}]}], ",", "30"}], "]"}], ",", 
         RowBox[{"N", "[", 
